# Database
POSTGRES_USER=promptlab
POSTGRES_PASSWORD=promptlab_secret
POSTGRES_DB=promptlab
DATABASE_URL=postgresql+asyncpg://promptlab:promptlab_secret@localhost:5432/promptlab

# Redis
REDIS_URL=redis://localhost:6379/0

# Clerk (Frontend + Backend)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=sk_test_YOUR_CLERK_SECRET_KEY
CLERK_JWT_ISSUER=https://your-domain.clerk.accounts.dev

# Backend
SECRET_KEY=change-this-super-secret-key-in-production
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# LLM (OpenAI-compatible endpoint)
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
