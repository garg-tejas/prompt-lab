# Database
POSTGRES_USER=promptlab
POSTGRES_PASSWORD=promptlab_secret
POSTGRES_DB=promptlab
DATABASE_URL=postgresql+asyncpg://promptlab:promptlab_secret@localhost:5432/promptlab

# Redis
REDIS_URL=redis://localhost:6379/0

# Clerk (get these from https://dashboard.clerk.com/last-active?path=api-keys)
# 1. VITE_CLERK_PUBLISHABLE_KEY — copy "Publishable key" (starts with pk_test_ or pk_live_)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# 2. CLERK_SECRET_KEY — copy "Secret key" (starts with sk_test_ or sk_live_)
CLERK_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# 3. CLERK_JWT_ISSUER — your Frontend API URL without trailing slash
#    Example: https://useful-pegasus-7.clerk.accounts.dev
CLERK_JWT_ISSUER=https://your-frontend-api-url.clerk.accounts.dev

# Backend
SECRET_KEY=change-this-super-secret-key-in-production
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# LLM (OpenAI-compatible endpoint)
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
